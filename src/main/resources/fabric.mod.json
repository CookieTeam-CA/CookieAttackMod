{
    "schemaVersion": 1,
    "id": "cookieattack",
    "version": "${version}",
    "name": "CookieAttackMod",
    "description": "Client-side CookieAttack mod that sets the application icon and title on startup",
    "authors": [
        "CookieAttack"
    ],
    "contact": {
        "homepage": "https://de.cookieattack",
        "issues": "https://de.cookieattack/issues",
        "sources": "https://de.cookieattack/source"
    },
    "license": "MIT",
    "icon": "assets/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "de.cookieattack.cookieattackmod.CookieAttackMod"
        ]
    },
    "mixins": [
        "cookieattack.mixins.json"
    ],
    "depends": {
        "minecraft": ">=26.2",
        "fabricloader": ">=0.18.4",
        "java": ">=25"
    }
}